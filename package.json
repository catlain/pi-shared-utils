{
  "name": "@pi-atelier/shared-utils",
  "version": "1.0.0",
  "description": "Shared utilities for pi-atelier extensions — settings, project config, memory parsing, tool output truncation, and more",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true
  },
  "files": [
    "src/",
    "README.md",
    "README.en.md",
    "tsconfig.json",
    "vitest.config.ts",
    "package.json"
  ]
}
