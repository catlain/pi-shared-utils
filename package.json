{
	"name": "@pi-atelier/shared-utils",
	"version": "1.1.0",
	"description": "Shared utilities for pi-atelier extensions — settings, project config, memory parsing, tool output truncation, and more",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./*": "./src/*.ts"
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"lint": "biome check lib src index.ts",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.6.0"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-coding-agent": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@vitest/coverage-v8": "^3.2.4",
		"tsup": "^8.0.0",
		"typescript": "^6.0.3",
		"vitest": "^3.0.0"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"format": [
			"esm"
		],
		"dts": true,
		"clean": true
	},
	"files": [
		"src/",
		"README.md",
		"README.en.md",
		"tsconfig.json",
		"vitest.config.ts",
		"package.json"
	],
	"keywords": [
		"pi-package"
	],
	"homepage": "https://catlain.github.io/pi-atelier/",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/catlain/pi-shared-utils.git"
	},
	"bugs": {
		"url": "https://github.com/catlain/pi-shared-utils/issues"
	},
	"license": "MIT"
}
