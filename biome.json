{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"extends": ["../../../../config/lint-base.json"],
	"files": {
		"includes": ["src/**/*.ts"]
	},
	"formatter": {
		"lineWidth": 120
	},
	"linter": {
		"rules": {
			"correctness": {
				"noUnusedImports": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}
